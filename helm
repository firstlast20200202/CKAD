helm search hub wordpress    //hub is a repo
//search other repo
helm repo add bitnami http://charts.bitnami.com/bitnami
helm search repo wordpress      //search specific package from all the added repo
helm repo list

//once the charm is found, install the helm charm from a repo:
$ helm install [release-name] [chart-name]      //release means package here
$ helm install release-1 bitnami/wordpress
$ helm list
$ helm uninstall my-release
$ helm pull -untar bitnami/wordpress      //only download, not install
$ ls wordpress      //get chart contents
