k -n external get svc    //get name web-app and port 8080

vi ingress.yaml    //create yaml file of ingress

metadata:
  name: web-app-ingress
  namespace: external            //add
spec:
  ingressClassName: traefik      //edit
  rules:
  - host: "external.sterling-bengal.local"        //add
    http:
      paths:
      - path: /                //edit
        pathType: Prefix
        backend:
          service:
            name: web-app      //edit
            port:
              number: 8080      //edit

k apply -f ingress.yaml -n external

//verify
curl -L external.sterling-bengal.local
